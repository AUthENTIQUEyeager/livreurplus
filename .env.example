# ============================================
# LivreurPlus - Configuration Environment
# ============================================
# Copier ce fichier en .env et remplir les valeurs

# --- BASE DE DONNÉES ---
# MySQL (WAMP local)
DATABASE_URL="mysql://root:@localhost:3306/livreurplus"

# PostgreSQL (production)
# DATABASE_URL="postgresql://user:password@localhost:5432/livreurplus"

# --- SERVEUR ---
PORT=5000
NODE_ENV=development

# --- JWT ---
# Générer une clé secrète forte pour la production :
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=livreurplus_secret_key_changez_en_production
JWT_EXPIRES_IN=7d

# --- UPLOADS ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# --- FRONTEND URL (CORS) ---
FRONTEND_URL=http://localhost:3000
